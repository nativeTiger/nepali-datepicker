{
  "name": "react-bs-calendar",
  "version": "1.0.0",
  "description": "Production-ready Nepali (Bikram Sambat) date picker for React — single date, date range, time picker, keyboard navigation, Devanagari locale, and shadcn/ui design system.",
  "keywords": [
    "nepali",
    "bikram sambat",
    "nepali calendar",
    "nepali date picker",
    "bs calendar",
    "react",
    "shadcn",
    "radix-ui",
    "tailwindcss",
    "date range",
    "time picker"
  ],
  "homepage": "https://github.com/nativeTiger/nepali-datepicker#readme",
  "bugs": "https://github.com/nativeTiger/nepali-datepicker/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nativeTiger/nepali-datepicker.git"
  },
  "license": "MIT",
  "author": "nativeTiger",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "nepali-date-converter": ">=3.0.0",
    "lucide-react": ">=0.400.0",
    "@radix-ui/react-popover": ">=1.0.0",
    "@radix-ui/react-select": ">=2.0.0",
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "nepali-date-converter": "^3.4.0",
    "lucide-react": "^0.462.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
